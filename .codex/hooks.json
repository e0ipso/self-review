{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./.codex/hooks/kk-capture.cjs",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./.codex/hooks/kk-lint-tick.cjs",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./.codex/hooks/kk-session-start.cjs",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./.codex/hooks/kk-proposal-drain.cjs",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
